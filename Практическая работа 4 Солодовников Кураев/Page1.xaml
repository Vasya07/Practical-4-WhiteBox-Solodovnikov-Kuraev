<Page x:Class="Практическая_работа_4_Солодовников_Кураев.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 1 - Основная формула">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Row="0" Grid.ColumnSpan="2" 
                   Source="/Images/formula12_1.png" 
                   Height="90" Margin="5" 
                   ToolTip="Формула из задания"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="tbx" Grid.Row="1" Grid.Column="1" 
                     Margin="5" Padding="5" 
                     HorizontalAlignment="Stretch"
                     MinWidth="200"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="60"
                     VerticalScrollBarVisibility="Auto"
                     ToolTip="Введите значение X"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Y:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="tby" Grid.Row="2" Grid.Column="1" 
                     Margin="5" Padding="5" 
                     HorizontalAlignment="Stretch"
                     MinWidth="200"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="60"
                     VerticalScrollBarVisibility="Auto"
                     ToolTip="Введите значение Y"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Z:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="tbz" Grid.Row="3" Grid.Column="1" 
                     Margin="5" Padding="5" 
                     HorizontalAlignment="Stretch"
                     MinWidth="200"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="60"
                     VerticalScrollBarVisibility="Auto"
                     ToolTip="Введите значение Z"/>

            <StackPanel Grid.Row="4" Grid.Column="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Left" 
                        Margin="5">
                <Button x:Name="CalculateButton" 
                        Content="Вычислить" 
                        Width="100" Height="35" Margin="0,0,10,0"
                        Click="CalculateButton_Click"
                        ToolTip="Вычислить значение функции"/>
                <Button x:Name="ClearButton" 
                        Content="Очистить" 
                        Width="100" Height="35"
                        Click="ClearButton_Click"
                        ToolTip="Очистить все поля"/>
            </StackPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Результат:" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="ResultTextBox" Grid.Row="5" Grid.Column="1"
                     IsReadOnly="True" Background="#FFF0F0F0"
                     Margin="5" Padding="8" MinHeight="45" 
                     FontSize="16" FontWeight="Bold"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     MaxHeight="100"
                     ToolTip="Результат вычисления"/>
        </Grid>
    </ScrollViewer>
</Page>