<Window x:Class="Практическая_работа_4_Солодовников_Кураев.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4: Солодовников И Кураев" 
        Height="700" 
        Width="1000"
        WindowStyle="SingleBorderWindow"
        Background="#FFF5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FF4A90E2" CornerRadius="0,0,10,10" Padding="10">
            <StackPanel>
                <TextBlock Text="Практическая работа №4" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Солодовников И Кураев" 
                           FontSize="18" 
                           Foreground="#FFF0F0F0" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>

                <TextBlock Text="&quot;Мы не волшебники, мы только учимся... но WPF уже боится нас!&quot;" 
                           FontSize="14" 
                           FontStyle="Italic" 
                           Foreground="#FFE0E0E0" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" 
                    Background="#FF2C3E50" 
                    CornerRadius="10" 
                    Margin="0,0,10,0"
                    Padding="15">

                <StackPanel>
                    <Button x:Name="ButtonPage1" 
                            Click="ButtonPage1_Click"
                            Height="70"
                            Margin="0,5"
                            Background="#FF3498DB"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            ToolTip="Тут живёт страшная формула...">
                        <StackPanel Margin="10,5">
                            <TextBlock Text="Страница 1" 
                                       FontSize="16"
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Основная формула" 
                                       FontSize="12"
                                       Foreground="#FFD0D0D0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ButtonPage2" 
                            Click="ButtonPage2_Click"
                            Height="70"
                            Margin="0,5"
                            Background="#FFE67E22"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            ToolTip="Тут функции прыгают как бешеные">
                        <StackPanel Margin="10,5">
                            <TextBlock Text="Страница 2" 
                                       FontSize="16"
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Условная функция" 
                                       FontSize="12"
                                       Foreground="#FFD0D0D0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ButtonPage3" 
                            Click="ButtonPage3_Click"
                            Height="70"
                            Margin="0,5"
                            Background="#FF27AE60"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            ToolTip="Графики, графики, графики...">
                        <StackPanel Margin="10,5">
                            <TextBlock Text="Страница 3" 
                                       FontSize="16"
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            <TextBlock Text="Табуляция функции" 
                                       FontSize="12"
                                       Foreground="#FFD0D0D0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" 
                    Background="White" 
                    CornerRadius="10" 
                    Padding="15"
                    BorderBrush="#FFDDDDDD"
                    BorderThickness="1">
                <Frame x:Name="MainFrame" 
                       NavigationUIVisibility="Hidden"
                       Background="White"/>
            </Border>
        </Grid>
        <Border Grid.Row="2" 
                Background="#FF2C3E50" 
                CornerRadius="10,10,0,0" 
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=""/>
                <TextBlock Grid.Column="1" 
                           Text="Работает на честном слове и энтузиазме" 
                           Foreground="#FFFFAA00" 
                           FontSize="12"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" 
                           Text="Версия 4.2.0 &quot;Why so serious?&quot;" 
                           Foreground="#FFAAAAAA" 
                           FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>