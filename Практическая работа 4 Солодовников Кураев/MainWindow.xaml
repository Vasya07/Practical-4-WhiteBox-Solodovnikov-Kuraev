<Window x:Class="Практическая_работа_4_Солодовников_Кураев.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 - Солодовников Кураев" 
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <TextBlock Text="Практическая работа №4" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>
        <Frame x:Name="MainFrame" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden"/>
        <Border Grid.Row="2" Background="#34495E" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="Page1Button" 
                        Content="Страница 1 - Основная формула" 
                        Width="200" Height="40" 
                        Margin="5"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ButtonPage1_Click"/>

                <Button x:Name="Page2Button" 
                        Content="Страница 2 - Условная функция" 
                        Width="200" Height="40" 
                        Margin="5"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ButtonPage2_Click"/>

                <Button x:Name="Page3Button" 
                        Content="Страница 3 - Табуляция" 
                        Width="200" Height="40" 
                        Margin="5"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ButtonPage3_Click"/>

                <Button x:Name="EasterEggButton" 
                        Content="Какая-то кнопка" 
                        Width="113" Height="40" 
                        Margin="5"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Click="EasterEggButton_Click"
                        ToolTip="Это какая-то красная кнопка, котороая делает что-то странное"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>